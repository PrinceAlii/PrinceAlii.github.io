---
import { name } from "spectre:globals";
import Icon from "./Icon.astro";

const path = Astro.url.pathname;
const isHome = path === "/" || path === "";
const isProjects = path.startsWith("/projects");
const isContact = path === "/contact" || path.startsWith("/contact/");
---
<nav aria-label="Primary">
  <a class="site-title" href="/">{name}</a>
  <ul id="primary-navigation">
    <li>
      <a href="/" class:list={{ active: isHome }} aria-current={isHome ? "page" : undefined}>Home</a>
    </li>
    <li class="nav-separator" aria-hidden="true">/</li>
    <li>
      <a href="/projects" class:list={{ active: isProjects }} aria-current={isProjects ? "page" : undefined}>Projects</a>
    </li>
    <li class="nav-separator" aria-hidden="true">/</li>
    <li>
      <a href="/contact" class:list={{ active: isContact }} aria-current={isContact ? "page" : undefined}>Contact</a>
    </li>
    <li class="nav-separator" aria-hidden="true">/</li>
    <li>
      <label class="sr-only" for="search">Search the site</label>
      <input id="search" type="text" placeholder="Search (Ctrl+K)" autocomplete="off" />
      <div id="search-results" aria-live="polite" aria-label="Search results"></div>
    </li>
    <li class="nav-separator" aria-hidden="true">/</li>
    <li>
      <button type="button" id="theme-toggle" aria-label="Toggle theme"><span class="theme-toggle-icons"><Icon type="lucide" name="sun" width={16} height={16} class="theme-icon" /><Icon type="lucide" name="moon" width={16} height={16} class="theme-icon" /></span></button>
    </li>
  </ul>
  <button class="mobile-nav-toggle" type="button" aria-label="Open navigation menu" aria-controls="primary-navigation" aria-expanded="false">
    <Icon type="lucide" name="menu" width={24} height={24} class="menu-closed" />
    <Icon type="lucide" name="x" width={24} height={24} class="menu-open" />
  </button>
</nav>
<script is:inline>
(() => {
  const themeToggle = document.getElementById("theme-toggle");
  const nav = document.querySelector("nav");
  const navToggle = document.querySelector(".mobile-nav-toggle");
  const searchElement = document.querySelector("#search");
  const searchResults = document.querySelector("#search-results");
  const navLinks = document.querySelectorAll('nav a[href="/"], nav a[href="/projects"], nav a[href="/contact"]');

  if (!themeToggle || !nav || !navToggle || !searchElement || !searchResults) {
    console.warn("Navbar skipped initialisation because expected nodes were missing.");
    return;
  }

  const searchEndpoint = "/pagefind/pagefind.js";
  const mobileQuery = window.matchMedia("(max-width: 640px)");
  const themeStorageKey = "theme";
  let pagefindModule = null;
  let searchDebounceId;
  let searchRequestId = 0;
  let currentFocusIndex = -1;

  const getStoredTheme = () => {
    try {
      return localStorage.getItem(themeStorageKey);
    } catch {
      return null;
    }
  };

  const setStoredTheme = (theme) => {
    try {
      localStorage.setItem(themeStorageKey, theme);
    } catch {
      // Keep the UI working even when storage is unavailable.
    }
  };

  const savedTheme = getStoredTheme();
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
  const initialTheme = savedTheme ?? (prefersDark ? "dark" : "light");

  document.documentElement.setAttribute("data-theme", initialTheme);

  const setThemeToggleLabel = () => {
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    themeToggle.setAttribute("aria-label", isDark ? "Switch to light theme" : "Switch to dark theme");
  };

  const updateThemeIcon = () => {
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    const icons = themeToggle.querySelectorAll(".theme-icon");
    const sun = icons[0];
    const moon = icons[1];
    sun?.classList.toggle("hidden", isDark);
    moon?.classList.toggle("hidden", !isDark);
    setThemeToggleLabel();
  };

  const createSearchResult = (data) => {
    const link = document.createElement("a");
    link.href = data.url;

    const title = document.createElement("h3");
    title.className = "no-mt";
    title.textContent = data?.meta?.title ?? "Untitled result";

    const excerpt = document.createElement("p");
    excerpt.textContent = String(data?.excerpt ?? "").replace(/<[^>]*>/g, "");

    link.append(title, excerpt);
    return link;
  };

  const renderSearchResults = (items, query) => {
    searchResults.replaceChildren();

    if (query.length > 0 && items.length === 0) {
      const empty = document.createElement("p");
      empty.style.marginTop = "0";
      empty.textContent = "No results found";
      searchResults.append(empty);
      searchResults.classList.add("active");
      return;
    }

    const fragment = document.createDocumentFragment();
    items.forEach((item, index) => {
      fragment.append(createSearchResult(item));
      if (index < items.length - 1) {
        const separator = document.createElement("hr");
        separator.className = "separator";
        separator.setAttribute("aria-hidden", "true");
        fragment.append(separator);
      }
    });

    searchResults.append(fragment);
    searchResults.classList.add("active");
  };

  const setMobileNavOpen = (open) => {
    nav.classList.toggle("active", open);
    navToggle.classList.toggle("active", open);
    navToggle.setAttribute("aria-expanded", String(open));
    navToggle.setAttribute("aria-label", open ? "Close navigation menu" : "Open navigation menu");
  };

  const updateSearchPlaceholder = () => {
    searchElement.placeholder = mobileQuery.matches ? "Search" : "Search (Ctrl+K)";
  };

  const closeSearchResults = () => {
    searchResults.classList.remove("active");
    currentFocusIndex = -1;
  };

  const getResultLinks = () => searchResults.querySelectorAll("a");

  const isSearchContextActive = () => {
    const activeElement = document.activeElement;

    return (
      searchResults.classList.contains("active") &&
      (activeElement === searchElement || searchResults.contains(activeElement))
    );
  };

  const getSearchApi = async () => {
    if (pagefindModule) {
      return pagefindModule;
    }

    try {
      pagefindModule = await import(searchEndpoint);
      if (typeof pagefindModule.init === "function") {
        await pagefindModule.init();
      }
      return pagefindModule;
    } catch (error) {
      console.error("Failed to initialise Pagefind:", error);
      return null;
    }
  };

  const runSearch = async (query, requestId) => {
    const api = await getSearchApi();
    if (!api || typeof api.search !== "function" || requestId !== searchRequestId) {
      return;
    }

    const search = await api.search(query);
    if (requestId !== searchRequestId) {
      return;
    }

    const items = [];
    for (const result of search.results ?? []) {
      items.push(await result.data());
      if (requestId !== searchRequestId) {
        return;
      }
    }

    renderSearchResults(items, query);
  };

  const scheduleSearch = (query) => {
    clearTimeout(searchDebounceId);
    searchRequestId += 1;
    const requestId = searchRequestId;

    if (!query.trim()) {
      closeSearchResults();
      searchResults.replaceChildren();
      return;
    }

    searchDebounceId = window.setTimeout(() => {
      void runSearch(query, requestId);
    }, 180);
  };

  const moveSearchFocus = (step) => {
    if (!isSearchContextActive()) {
      return false;
    }

    const links = getResultLinks();
    if (!links.length) {
      return false;
    }

    currentFocusIndex = (currentFocusIndex + step + links.length) % links.length;
    links[currentFocusIndex]?.focus();
    return true;
  };

  updateThemeIcon();
  updateSearchPlaceholder();
  setMobileNavOpen(false);

  themeToggle.addEventListener("click", () => {
    const currentTheme = document.documentElement.getAttribute("data-theme");
    const nextTheme = currentTheme === "dark" ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", nextTheme);
    setStoredTheme(nextTheme);
    updateThemeIcon();
  });

  navToggle.addEventListener("click", () => {
    const nextOpen = navToggle.getAttribute("aria-expanded") !== "true";
    setMobileNavOpen(nextOpen);
  });

  searchElement.addEventListener("focus", async () => {
    searchElement.placeholder = "";
    searchResults.classList.add("active");
    void getSearchApi();
  });

  searchElement.addEventListener("blur", () => {
    updateSearchPlaceholder();
    window.setTimeout(() => {
      if (!document.activeElement?.closest("#search-results")) {
        closeSearchResults();
      }
    }, 1);
  });

  searchResults.addEventListener("focusout", (event) => {
    if (!event.relatedTarget?.closest("#search-results")) {
      closeSearchResults();
    }
  });

  searchElement.addEventListener("input", () => {
    scheduleSearch(searchElement.value);
  });

  document.addEventListener("keydown", (event) => {
    if (event.ctrlKey && event.key === "k") {
      event.preventDefault();
      searchElement.focus();
      searchElement.select();
      return;
    }

    if (event.key === "Escape") {
      closeSearchResults();
      setMobileNavOpen(false);
      searchElement.blur();
      return;
    }

    if (event.key === "ArrowDown" && moveSearchFocus(1)) {
      event.preventDefault();
      return;
    }

    if (event.key === "ArrowUp" && moveSearchFocus(-1)) {
      event.preventDefault();
      return;
    }
  });

  mobileQuery.addEventListener("change", updateSearchPlaceholder);
  window.addEventListener("resize", updateSearchPlaceholder);

  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (mobileQuery.matches) {
        setMobileNavOpen(false);
      }
    });
  });
})();
</script>
<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  nav {
    --nav-mobile-trigger-size: 40px;
    --nav-mobile-panel-offset: calc(1rem + var(--nav-mobile-trigger-size));
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Geist Mono', 'Courier New', Courier, monospace;
    font-size: var(--text-size-sm);
    line-height: var(--text-leading-meta);
    letter-spacing: var(--text-tracking-meta);
    font-weight: var(--text-weight-medium);
    z-index: 50;
  }

  .site-title {
    font-weight: var(--text-weight-display);
    text-decoration: none;
    font-size: var(--text-size-title);
    line-height: var(--text-leading-tight);
    letter-spacing: var(--text-tracking-display);
    z-index: 2;
  }

  nav ul {
    display: flex;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style-type: none;
    align-items: center;
    flex-shrink: 0;
  }

  nav ul li {
    position: relative;
  }

  nav a {
    color: inherit;
    text-decoration: none;
    padding: .25rem .5rem;
  }

  /* Main nav links only (not the site title) so active/hover always reads on primary */
  nav ul a:hover,
  nav ul a:focus-visible,
  nav ul a.active {
    background-color: var(--primary);
    color: var(--text-on-primary);
    outline: none;
    text-decoration: none;
  }

  #search {
    background: none;
    border: none;
    outline: none;
    padding: .25rem .5rem;
    box-sizing: border-box;
    width: 12rem;
    min-width: 12rem;
    max-width: 100%;
    color: var(--text-color);
    font-variant-numeric: tabular-nums;
  }

  #search::placeholder {
    color: var(--text-muted);
  }

  #search:focus {
    background-color: var(--primary);
  }

  #search-results {
    position: absolute;
    top: calc(100% + .5rem);
    right: 0;
    background-color: var(--card-bg);
    border: 1px solid var(--primary);
    display: none;
    width: 200%;
    z-index: 10;
    padding: .5rem;
  }

  #search-results.active:has(*) {
    display: block;
  }

  .mobile-nav-toggle {
    display: none;
    width: 40px;
    height: 40px;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
  }

  .menu-open {
    display: none;
  }

  .mobile-nav-toggle.active .menu-open {
    display: flex;
  }

  .mobile-nav-toggle.active .menu-closed {
    display: none;
  }

  #theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: none;
    border: 1px solid var(--border-color);
    cursor: pointer;
    color: var(--text-color);
    transition: background-color 0.15s ease;
    box-sizing: border-box;
    overflow: visible;
    -webkit-appearance: none;
    appearance: none;
  }

  .theme-toggle-icons {
    position: relative;
    width: 28px;
    height: 28px;
    flex: 0 0 auto;
    overflow: visible;
    pointer-events: none;
  }

  .theme-toggle-icons > :global(svg.theme-icon) {
    position: absolute;
    left: 50%;
    top: 50%;
    display: block;
    width: 13px;
    height: 13px;
    margin: 0;
    transform: translate(calc(-50% - 5px), calc(-50% - 5px));
    overflow: visible;
    box-sizing: border-box;
  }

  /* Beats #theme-toggle svg so .hidden can actually hide an icon */
  #theme-toggle :global(svg.theme-icon.hidden) {
    display: none;
  }

  #theme-toggle:hover, #theme-toggle:focus-visible {
    background-color: var(--primary);
    outline: none;
  }

  .theme-icon {
    transition: opacity 0.15s ease;
  }

  .theme-icon.hidden {
    display: none;
  }

  @media screen and (max-width: 640px) {
    nav {
      --nav-mobile-trigger-size: 44px;
      padding: 0 1rem;
      padding-top: 1rem;
      transition: all .25s ease;
    }

    .mobile-nav-toggle {
      display: flex;
    }

    .nav-separator {
      display: none;
    }

    nav ul {
      flex-direction: column;
      gap: 0;
      position: absolute;
      width: 100%;
      top: var(--nav-mobile-panel-offset);
      right: 0;
      padding: 1rem;
      z-index: 1;
      opacity: 0;
      pointer-events: none;
      transition: all .25s ease;
      user-select: none;
      height: calc(100vh - var(--nav-mobile-panel-offset));
      align-items: start;
    }

    nav.active {
      background-color: var(--bg-color);
    }

    nav.active ul {
      opacity: 1;
      pointer-events: all;
      background-color: var(--bg-color);
    }

    nav ul li {
      position: relative;
      transition: all .25s ease-out;
      top: -1.5rem;
      border-bottom: 1px solid var(--border-color);
      width: 100%;
      max-width: none;
      padding: 0;
      font-size: var(--text-size-body);
    }
  
    nav ul li a {
      display: block;
      min-height: 44px;
      padding: .875rem 0;
      width: 100%;
      padding-left: 1rem;
    }

    nav ul li:first-child {
      border-top: 1px solid var(--border-color);
    }

    nav.active ul li {
      top: 0;
    }

    #search {
      width: 100%;
      max-width: none;
      min-width: 0;
      min-height: 44px;
      padding: .875rem 1rem;
    }

    #search-results {
      width: 100%;
      top: 100%;
      font-size: var(--text-size-sm);
    }

    #theme-toggle,
    .mobile-nav-toggle {
      width: var(--nav-mobile-trigger-size);
      height: var(--nav-mobile-trigger-size);
      min-width: var(--nav-mobile-trigger-size);
      min-height: var(--nav-mobile-trigger-size);
    }
  }
</style>
<style is:global>
  #search-results a {
    display: block;
    text-decoration: none;
    color: var(--text-color) !important;
    padding: .5rem;
  }

  #search-results a:hover, #search-results a:focus-visible {
    background-color: var(--primary);
    outline: none;
  }

  #search-results a:hover mark, #search-results a:focus-visible mark {
    background-color: var(--text-on-primary);
    color: var(--primary);
  }

  #search-results a h3 {
    margin-bottom: .5rem;
    font-size: var(--text-size-body);
    line-height: 1.35;
  }

  #search-results a p {
    margin: 0;
    font-size: var(--text-size-sm);
    line-height: var(--text-leading-meta);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #search-results mark {
    background-color: var(--primary);
    color: var(--text-on-primary);
  }

  .separator {
    margin: .5rem .5rem;
    border: none;
    height: 1px;
    background-color: var(--border-color);
  }
</style>

---
import Layout from "@/src/layouts/Layout.astro";
import { useI18n } from "@ariaskit/astro-i18n";
import { getCollection } from "astro:content";
import { type LocaleSchema } from "@/src/types";
import Header from "@/src/components/Header.astro";
import Hero from "@/src/components/Hero.astro";
import Education from "@/src/components/Education.astro";
import Projects from "@/src/components/Projects.astro";
import Experience from "@/src/components/Experience.astro";
import Footer from "@/src/components/Footer.astro";
import Skills from "@/src/components/Skills.astro";

const { t } = useI18n<LocaleSchema>({
  ssg: {
    astro: Astro,
    locale: "en",
  },
});

const nav = [
  { path: `/`, text: t("nav.about") },
  { path: `#${t("nav.experience")}`, text: t("nav.experience") },
  { path: `#${t("nav.education")}`, text: t("nav.education") },
  { path: `#${t("nav.projects")}`, text: t("nav.projects") },
  { path: `#${t("nav.contact")}`, text: t("nav.contact") },
];

const heroProps = {
  name: "Ali Bonagdaran",
  title: { key: "hero.title", value: t("hero.title") },
  p1: { key: "hero.p1", value: t("hero.p1") },
  p2: { key: "hero.p2", value: t("hero.p2") },
  p3: { key: "hero.p3", value: t("hero.p3") },
};

const projectEntries = await getCollection(
  "projects",
  ({ data }) => !data.draft
);
projectEntries.sort((a, b) => a.data.order - b.data.order);
const projects = projectEntries.map((entry) => ({
  nameKey: `projects.md.${entry.slug}.title`,
  descriptionKey: `projects.md.${entry.slug}.description`,
  name: entry.data.title,
  description: entry.data.description,
  link: entry.data.link,
}));

const projectsProps = {
  title: { key: "projects.title", value: t("projects.title") },
  projects,
};

const educationData = {
  title: {
    key: "education.title",
    value: t("education.title"),
  },
  jobs: [
    {
      period: {
        key: "education.item_1.period",
        value: t("education.item_1.period"),
      },
      role: {
        key: "education.item_1.role",

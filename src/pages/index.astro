---
export const prerender = true;

import "../styles/index.css";

import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry, render } from "astro:content";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { name, openGraph } from "spectre:globals";
import absLogoUrl from "../assets/employers/abs.svg?url";
import cbaLogo from "../assets/employers/cba.jpg";
import mcdonaldsLogo from "../assets/employers/mcdonalds.jpg";
import serviceLogo from "../assets/employers/service.jpg";
import ProfilePicture from "../assets/profile.png";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import ImageGlow from "../components/ImageGlow.astro";
import Layout from "../layouts/Layout.astro";

const [projects, about, workExperience, quickInfo, socials] =
	await Promise.all([
		getCollection("projects"),
		getEntry("other", "about"),
		getCollection("workExperience"),
		getCollection("quickInfo"),
		getCollection("socials"),
	]);

const { Content: About } = await render(about!);

function splitCompanyLocation(company: string): {
	name: string;
	location: string | null;
} {
	const idx = company.indexOf(" · ");
	if (idx === -1) {
		return { name: company, location: null };
	}
	return {
		name: company.slice(0, idx),
		location: company.slice(idx + 3),
	};
}

function companySpanLabel(roles: CollectionEntry<"workExperience">[]): string {
	if (roles.length === 0) return "";
	if (roles.length === 1) return roles[0].data.duration;
	const oldest = roles[roles.length - 1].data.duration;
	const newest = roles[0].data.duration;
	const start = oldest.split(" - ")[0]?.trim() ?? "";
	const endParts = newest.split(" - ");
	const end = endParts[endParts.length - 1]?.trim() ?? "";
	return start && end ? `${start} - ${end}` : newest;
}

function groupWorkByConsecutiveCompany(
	entries: CollectionEntry<"workExperience">[],
): { company: string; roles: CollectionEntry<"workExperience">[] }[] {
	const ordered = [...entries].reverse();
	const groups: {
		company: string;
		roles: CollectionEntry<"workExperience">[];
	}[] = [];
	for (const entry of ordered) {
		const last = groups[groups.length - 1];
		if (last?.company === entry.data.company) {
			last.roles.push(entry);
		} else {
			groups.push({ company: entry.data.company, roles: [entry] });
		}
	}
	return groups;
}

function companyMonogram(companyName: string): string {
	const c = companyName.replace(/^[^A-Za-z0-9]+/, "").charAt(0);
	return c ? c.toUpperCase() : "·";
}

type EmployerLogo =
	| { kind: "raster"; src: ImageMetadata }
	| { kind: "vector"; src: string };

function getEmployerLogo(companyName: string): EmployerLogo | null {
	switch (companyName) {
		case "Australian Bureau of Statistics":
			return { kind: "vector", src: absLogoUrl };
		case "Commonwealth Bank of Australia":
			return { kind: "raster", src: cbaLogo };
		case "McDonald's":
			return { kind: "raster", src: mcdonaldsLogo };
		case "Service NSW":
			return { kind: "raster", src: serviceLogo };
		default:
			return null;
	}
}

const workGroups = groupWorkByConsecutiveCompany(workExperience);
---

<Layout
	title={openGraph.home.title || name}
	description={openGraph.home.description}
	pagefindIgnore
>
	<div class="layout-grid-left" slot="left">
		<Card class="flex-col-card">
			<ImageGlow
				quality={100}
				width={120}
				height={120}
				src={ProfilePicture}
				alt="Profile picture"
				loading="eager"
			/>
			<h2>{name}</h2>
			<ul class="overview-list">
				{
					quickInfo.map((info) => (
						<li>
							<span class="overview-icon-wrap">
								<Icon
									type={info.data.icon.type}
									name={info.data.icon.name as any}
									width={24}
									height={24}
									class="glow-icon"
								/>
							</span>
							{info.data.lines ? (
								<span class="quick-info-lines">
									{info.data.lines.map((line, i) => (
										<span
											class:list={[
												"qi-line",
												{ "qi-line-dates": i === info.data.lines!.length - 1 },
											]}
										>
											{line}
										</span>
									))}
								</span>
							) : (
								<span>{info.data.text}</span>
							)}
						</li>
					))
				}
			</ul>
		</Card>
		<Card>
			<h3 class="no-mt">Get in touch</h3>
			<ul class="overview-list">
				{
					socials.map((item) => (
						<li>
							<a href={item.data.link} class="socials-link">
								<span class="overview-icon-wrap">
									<Icon
										type={item.data.icon.type}
										name={item.data.icon.name as any}
										width={24}
										height={24}
										class="glow-icon"
									/>
								</span>
								<span>{item.data.text}</span>
							</a>
						</li>
					))
				}
			</ul>
		</Card>
	</div>
	<div class="layout-grid-right" slot="right">
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="user"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>About me</h2>
			</div>
			<div class="prose">
				<About />
			</div>
		</Card>
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="folder-git"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Projects</h2>
			</div>
			<div class="content-container">
				{
					projects
						.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
						.slice(0, 2)
						.map((project) => (
							<a href={`/projects/${project.id}`} class="post-container">
								<div class="post-header">
									<h3>{project.data.title}</h3>
									<span class="post-date">
										{project.data.date.toLocaleDateString()}
									</span>
								</div>
								<span>{project.data.description}</span>
							</a>
						))
				}
			</div>
		</Card>
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="briefcase-business"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Work Experience</h2>
			</div>
			<div class="work-experience-container">
				{
					workGroups.map((group) => {
						const { name: companyName, location: companyLocation } =
							splitCompanyLocation(group.company);
						const locationLine =
							companyLocation != null && companyLocation.length > 0
								? companyLocation
								: null;
						const employerLogo = getEmployerLogo(companyName);
						return (
							<section class="work-experience-group">
								<div class="work-company-header">
									<div
										class:list={[
											"work-company-logo",
											{
												"work-company-logo--monogram": employerLogo == null,
												"work-company-logo--vector":
													employerLogo?.kind === "vector",
												"work-company-logo--raster":
													employerLogo?.kind === "raster",
											},
										]}
										aria-hidden="true"
									>
										{employerLogo == null ? (
											<span class="work-company-monogram">
												{companyMonogram(companyName)}
											</span>
										) : employerLogo.kind === "vector" ? (
											<img
												src={employerLogo.src}
												alt=""
												class="work-company-logo-media work-company-logo-media--vector"
												width="56"
												height="56"
												decoding="async"
												loading="lazy"
											/>
										) : (
											<Image
												src={employerLogo.src}
												alt=""
												width={56}
												height={56}
												class="work-company-logo-media work-company-logo-media--raster"
												loading="lazy"
												densities={[1, 2]}
											/>
										)}
									</div>
									<div class="work-company-meta">
										<h3 class="work-company-name">{companyName}</h3>
										<p class="work-company-span">
											{companySpanLabel(group.roles)}
										</p>
									</div>
								</div>
								{group.roles.length > 1 ? (
									<div class="work-roles-timeline">
										{group.roles.map((entry, roleIndex) => (
											<div class="work-role-row">
												<div class="work-role-rail">
													<span class="work-role-dot" />
													{roleIndex < group.roles.length - 1 ? (
														<span class="work-role-connector" />
													) : null}
												</div>
												<div class="work-role-body">
													<h4 class="work-role-title">{entry.data.title}</h4>
													<p class="work-role-duration">{entry.data.duration}</p>
													{locationLine ? (
														<p class="work-role-location">{locationLine}</p>
													) : null}
												</div>
											</div>
										))}
									</div>
								) : (
									<div class="work-single-role">
										<h4 class="work-role-title">
											{group.roles[0].data.title}
										</h4>
										<p class="work-role-duration">
											{group.roles[0].data.duration}
										</p>
										{locationLine ? (
											<p class="work-role-location">{locationLine}</p>
										) : null}
									</div>
								)}
							</section>
						);
					})
				}
			</div>
		</Card>
	</div>
</Layout>

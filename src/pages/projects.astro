---
export const prerender = true;

import "../styles/article-list.css";

import { getCollection } from "astro:content";
import { openGraph } from "spectre:globals";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";

const projects = await getCollection("projects");
const latestProjects = [...projects].sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latestProjectDate = latestProjects[0]?.data.date;
---
<Layout
	title={openGraph.projects.title || "Projects"}
	description={openGraph.projects.description}
	pagefindIgnore
>
  <div class="layout-grid-left" slot="left">
    <Card class="flex-col-card">
      <h2 class="no-mt">Stats</h2>
				<div class="stats-div">
					<div class="stat">
						<h3 class="text-glow">{projects.length}</h3>
						<span>Published project{projects.length === 1 ? "" : "s"}</span>
						{latestProjectDate ? (
							<span class="stat-meta">
								Latest update: {latestProjectDate.toLocaleDateString()}
							</span>
						) : null}
					</div>
				</div>
    </Card>
  </div>
	  <div class="layout-grid-right" slot="right">
			<Card>
				<div class="header-container">
					<Icon type='lucide' name="folder-git" width={24} height={24} class='glow-icon' />
					<h2>Latest Projects</h2>
				</div>
				<div class="content-container">
					{latestProjects.length > 0 ? (
						latestProjects.map((post) => (
							<a href={`/projects/${post.id}`} class="post-container">
								<div class="post-header">
									<h3>{post.data.title}</h3>
									<span class="post-date">{post.data.date.toLocaleDateString()}</span>
								</div>
								<span>{post.data.description}</span>
							</a>
						))
					) : (
						<div class="empty-state" role="status" aria-live="polite">
							<h3 class="empty-state-title">No projects published yet</h3>
							<p class="empty-state-copy">
								This section will list projects once content is added to the
								collection.
							</p>
							<a href="/" class="block-link">Return to the homepage</a>
						</div>
					)}
				</div>
			</Card>
	  </div>
	</Layout>
<style>
	.stats-div {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
	}

	.stat h3 {
		font-size: clamp(2rem, 1.5rem + 2.1vw, 3rem);
		line-height: var(--text-leading-tight);
		letter-spacing: var(--text-tracking-display);
		margin: 0;
		margin-bottom: var(--space-xs);
		font-variant-numeric: tabular-nums;
	}

	.stat span {
		font-family: "Geist Mono", "Courier New", Courier, monospace;
		font-size: var(--text-size-sm);
		line-height: var(--text-leading-meta);
		letter-spacing: var(--text-tracking-meta);
	}

	.stat-meta {
		color: var(--text-muted);
		overflow-wrap: anywhere;
		word-break: normal;
	}

	.empty-state {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		padding: var(--space-md);
		border: 1px solid var(--border-color);
		background: var(--surface-accent-soft);
	}

	.empty-state-title {
		margin: 0;
		font-size: var(--text-size-lead);
		line-height: var(--text-leading-heading);
	}

	.empty-state-copy {
		margin: 0;
		max-width: 40ch;
		color: var(--text-muted);
		line-height: var(--text-leading-body);
	}

	@media screen and (max-width: 640px) {
		.stat h3 {
			margin-bottom: 0.25rem;
		}

		.stat span {
			font-size: 0.8125rem;
		}
	}

</style>

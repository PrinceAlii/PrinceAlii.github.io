---
export const prerender = true;

import { getCollection } from "astro:content";
import { name } from "spectre:globals";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";

const socials = await getCollection("socials");

const pageTitle = `Contact · ${name}`;
const pageDescription =
	"Get in touch via email, LinkedIn, or GitHub. Sydney, Australia.";
---

<Layout title={pageTitle} description={pageDescription}>
	<div class="layout-grid-left" slot="left">
		<Card class="flex-col-card">
			<h2 class="no-mt">Say hello</h2>
			<p class="contact-aside">
				If you're hiring or keen to chat about cloud and DevOps, I'd love to
				hear from you. Email is usually the quickest way to reach me.
			</p>
			<p class="contact-aside contact-aside-muted">
				Based in Sydney, Australia.
			</p>
		</Card>
	</div>
	<div class="layout-grid-right" slot="right">
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="mail"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Contact</h2>
			</div>
			<ul class="contact-methods">
				{
					socials
						.sort((a, b) => a.data.id - b.data.id)
						.map((item) => {
							const isMail = item.data.link.startsWith("mailto:");
							const displayHref = isMail
								? item.data.link.replace(/^mailto:/, "")
								: item.data.link;
							const externalAttrs = isMail
								? {}
								: {
										target: "_blank",
										rel: "noopener noreferrer",
									};
							return (
								<li>
									<a
										href={item.data.link}
										class="contact-method-link"
										{...externalAttrs}
									>
										<span class="overview-icon-wrap contact-method-icon-wrap">
											<Icon
												type={item.data.icon.type}
												name={item.data.icon.name as any}
												width={24}
												height={24}
												class="glow-icon"
											/>
										</span>
										<span class="contact-method-body">
											<span class="contact-method-label">{item.data.text}</span>
											<span class="contact-method-href">{displayHref}</span>
										</span>
									</a>
								</li>
							);
						})
				}
			</ul>
		</Card>
	</div>
</Layout>

<style>
	.contact-aside {
		margin: 0 0 var(--space-sm);
		line-height: var(--text-leading-body);
		font-size: var(--text-size-body);
		max-width: 46ch;
	}

	.contact-aside-muted {
		margin: var(--space-2xs) 0 0;
		color: var(--text-muted);
		font-size: var(--text-size-sm);
		line-height: var(--text-leading-meta);
		font-family: "Geist Mono", "Courier New", Courier, monospace;
		font-variant-numeric: tabular-nums;
		letter-spacing: var(--text-tracking-meta);
	}

	.contact-methods {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.contact-methods li {
		border-bottom: 1px solid var(--border-color);
	}

	.contact-methods li:last-child {
		border-bottom: none;
	}

	.contact-method-link {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		gap: var(--space-sm);
		padding: var(--space-sm) 0;
		color: inherit;
		text-decoration: none;
		transition:
			background-color 0.15s ease,
			color 0.15s ease;
		margin: 0 calc(-1 * var(--space-sm));
		padding-left: var(--space-sm);
		padding-right: var(--space-sm);
		border-radius: 0;
	}

	.contact-method-link:hover,
	.contact-method-link:focus-visible {
		background-color: var(--primary);
		outline: none;
		color: var(--text-on-primary);
		text-decoration: none;
	}

	.contact-method-link:hover .contact-method-href,
	.contact-method-link:focus-visible .contact-method-href {
		color: rgba(var(--text-on-primary-rgb), 0.92);
	}

	.contact-method-link:hover :global(svg.glow-icon),
	.contact-method-link:focus-visible :global(svg.glow-icon) {
		color: var(--primary);
		filter: none;
	}

	.contact-method-icon-wrap {
		flex-shrink: 0;
		padding: 0.2rem 0.3rem 0.35rem;
	}

	.contact-method-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xs);
		min-width: 0;
		flex: 1;
	}

	.contact-method-label {
		font-weight: var(--text-weight-medium);
		font-size: var(--text-size-body);
		line-height: 1.4;
	}

	.contact-method-href {
		font-size: var(--text-size-sm);
		color: var(--text-muted);
		overflow-wrap: anywhere;
		word-break: normal;
		hyphens: auto;
		font-family: "Geist Mono", "Courier New", Courier, monospace;
		line-height: var(--text-leading-meta);
		font-variant-numeric: tabular-nums;
		letter-spacing: var(--text-tracking-meta);
	}

	@media screen and (max-width: 640px) {
		.contact-aside {
			margin-bottom: var(--space-sm);
		}

		.contact-method-link {
			gap: var(--space-sm);
			padding-top: 0.72rem;
			padding-bottom: 0.72rem;
		}

		.contact-method-label {
			font-size: 0.95rem;
		}

		.contact-method-href {
			font-size: 0.8125rem;
		}
	}
</style>

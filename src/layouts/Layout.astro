---
import { PageMetadata } from "@/src/components/hybrid-astro-ui/page-metadata";
import OGImage from "@/src/assets/background.png"

interface Props {
	title: string;
	description: string;
	locale: string;
	alternateLinks?: { href: string; hreflang: string }[];
}

const { title, description, locale, alternateLinks } =
	Astro.props as Props;
---

<!doctype html>
<html lang={locale}>
	<head>
		<script is:inline>
			const getTheme = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return 'dark'; // Always Dark Default
			};

			const theme = getTheme();
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
			window.localStorage.setItem('theme', theme);
		</script>
		<PageMetadata
			lang={locale}
			title={title}
			description={description}
			image={OGImage}
			enableClientRouter
			ogType="website"
			favicons={[  { rel: "icon", type: "image/png", href: "/icon.png", sizes: "32x32" },]}
			alternateLinks={alternateLinks}
		/>
	</head>
	<body class="*:max-w-2xl *:w-full flex flex-col  items-center w-full font-mono px-5 md:px-0 leading-7" >
		<slot />
	</body>
</html>
